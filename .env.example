# Claude Science API Bridge Configuration
# Copy this file to .env, fill in the actual values, then run: docker compose up -d

# --- Custom Backend (e.g., SiliconFlow, Moonshot AI, etc.) ---
# API Key (required)
# CUSTOM_API_KEY=sk-your-api-key-here

# Third-party API endpoint
# CUSTOM_BASE_URL=https://api.siliconflow.cn

# Default backend: deepseek / openai / custom
# DEFAULT_BACKEND=custom

# Force-specified model name (takes precedence over default_backend)
# FORCE_MODEL=Pro/moonshotai/Kimi-K2.6

# Upstream protocol mode: openai / anthropic
# CUSTOM_UPSTREAM_MODE=openai

# Image handling policy: preserve / omit / omit_inline / auto
# INLINE_IMAGE_POLICY=preserve

# Reasoning/thinking content policy: never / auto / preserve
# When "never", strips thinking blocks incompatible with non-Anthropic backends
# REASONING_CONTENT_POLICY=never

# --- DeepSeek Backend (optional) ---
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_UPSTREAM_MODE=openai       # openai / anthropic

# --- OpenAI Backend (optional) ---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com

# --- Multi-Model Configuration (model_aliases) ---
# When set, enables model aliases mode for multi-model support.
# This overrides FORCE_MODEL and shows multiple models in Claude Science's model selector.
# Set as a JSON array; each entry maps a Claude-compatible ID to a real backend model.
#
# Example: DeepSeek Flash + Pro both available:
# MODEL_ALIASES='[{"id":"claude-haiku-4-5","display_name":"DeepSeek Flash","backend":"deepseek","model":"deepseek-chat"},{"id":"claude-sonnet-5","display_name":"DeepSeek Pro","backend":"deepseek","model":"deepseek-chat"}]'
#
# The entrypoint auto-sets model_list_mode=aliases + model_menu_strategy=claude_compatible
# when MODEL_ALIASES is provided. Override them manually if needed:
# MODEL_LIST_MODE=aliases
# MODEL_MENU_STRATEGY=claude_compatible