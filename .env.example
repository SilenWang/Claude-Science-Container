# Claude Science API Bridge Configuration
# Copy this file to .env, fill in the actual values, then run: docker compose up -d

# --- Custom Backend (e.g., SiliconFlow, Moonshot AI, etc.) ---
# API Key (required)
# CUSTOM_API_KEY=sk-your-api-key-here

# Third-party API endpoint
# CUSTOM_BASE_URL=https://api.siliconflow.cn

# Default backend: deepseek / openai / custom
# DEFAULT_BACKEND=custom

# Force-specified model name (takes precedence over default_backend)
# FORCE_MODEL=Pro/moonshotai/Kimi-K2.6

# Upstream protocol mode: openai / anthropic
# CUSTOM_UPSTREAM_MODE=openai

# Image handling policy: preserve / omit / omit_inline / auto
# INLINE_IMAGE_POLICY=preserve

# --- DeepSeek Backend (optional) ---
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- OpenAI Backend (optional) ---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com