# Claude Science API Bridge 配置
# 复制此文件为 .env 并填入实际值后执行: docker compose up -d

# --- 自定义后端（如硅基流动、月之暗面等）---
# API 密钥 (必填)
# CUSTOM_API_KEY=sk-your-api-key-here

# 第三方 API 地址
# CUSTOM_BASE_URL=https://api.siliconflow.cn

# 默认后端: deepseek / openai / custom
# DEFAULT_BACKEND=custom

# 强制使用的模型名称（优先级高于 default_backend）
# FORCE_MODEL=Pro/moonshotai/Kimi-K2.6

# 上游协议模式: openai / anthropic
# CUSTOM_UPSTREAM_MODE=openai

# 图片处理策略: preserve / omit / omit_inline / auto
# INLINE_IMAGE_POLICY=preserve

# --- DeepSeek 后端（可选）---
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# --- OpenAI 后端（可选）---
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com
